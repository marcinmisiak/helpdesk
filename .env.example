# ─── Baza danych ──────────────────────────────────────────────
DB_ROOT_PASSWORD=zmien_to_haslo_root
DB_NAME=helpdesk
DB_USER=helpdesk
DB_PASS=zmien_to_haslo

# ─── Backend ──────────────────────────────────────────────────
# Wygeneruj losowy klucz: openssl rand -hex 32
JWT_SECRET=zmien_to_na_losowy_dlugi_ciag_znakow
JWT_EXPIRES_IN=8h
# Czas życia tokenu przy zaznaczonej opcji "Zapamiętaj mnie" (opcjonalne, domyślnie 30d)
JWT_REMEMBER_EXPIRES_IN=30d

# URL pod którym działa aplikacja (bez trailing slash)
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost

# Port HTTP frontendu (domyślnie 80)
HTTP_PORT=80

# ─── OAuth Microsoft (opcjonalne) ─────────────────────────────
# azure.microsoft.com → App registrations → twoja aplikacja
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Tenant ID organizacji lub 'common' dla kont osobistych
MICROSOFT_TENANT_ID=common

# ─── OAuth Google (opcjonalne) ────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Web Push (opcjonalne) ────────────────────────────────────
# Wygeneruj: npx web-push generate-vapid-keys
VAPID_EMAIL=mailto:admin@twojadomena.pl
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Groq AI (opcjonalne) ─────────────────────────────────────
GROQ_API_KEY=
