{
  "name": "helpdesk",
  "version": "1.0.1",
  "description": "Helpdesk React + Node.js",
  "scripts": {
    "start": "bash start.sh",
    "backend": "cd backend && node src/app.js",
    "backend:dev": "cd backend && npx nodemon src/app.js",
    "frontend": "cd frontend && npm run dev -- --host 0.0.0.0",
    "frontend:build": "cd frontend && npm run build",
    "install:all": "cd backend && npm install && cd ../frontend && npm install"
  }
}
